# MySQL root password used by the database container
MYSQL_ROOT_PASSWORD=change_me

# Password for the application database user (must match MYSQL_ROOT_PASSWORD when using root)
DB_PASSWORD=change_me

# Hostname of the database service (use "db" when running via docker-compose)
DB_HOST=db

# Database username (use "root" for the default MySQL setup)
DB_USER=root

# Name of the MySQL database
DB_NAME=usersjira

# Port the database listens on inside the container
DB_PORT=3306

# AES encryption key for stored tokens — must be exactly 32 characters
ENCRYPTION_KEY=replace_with_32_char_secret_key!!

# Secret used to sign and verify JWTs
JWT_SECRET=replace_with_a_strong_jwt_secret

# Port the backend Express server listens on
PORT=4000
